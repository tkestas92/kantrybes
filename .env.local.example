# Railway MySQL - gauk iš Railway -> MySQL service -> Variables tab
# Railway duoda MYSQL_URL arba atskirus kintamuosius - naudok kuriuos turi
MYSQL_HOST=your_mysql_host
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=kantrybes_portfolio

# Admin slaptažodis admin panel'ui
ADMIN_PASSWORD=your_secure_password
